@model Student

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm border-0 rounded-4 p-4">

                <h3 class="text-center fw-bold mb-4">Add Student</h3>

                <form method="post">

                    <!-- Name -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input asp-for="Name" class="form-control rounded-3" placeholder="Enter full name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Class -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Class</label>
                        <select asp-for="Class" class="form-select rounded-3" id="classDropdown">
                            <option value="">-- Select Class --</option>
                            <option value="FY">FY</option>
                            <option value="SY">SY</option>
                            <option value="TY">TY</option>
                        </select>
                        <span asp-validation-for="Class" class="text-danger small"></span>
                    </div>

                    <!-- Roll No -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Roll Number</label>
                        <input asp-for="RollNo" class="form-control rounded-3 bg-light" id="rollNo" readonly placeholder="Auto-generated" />
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between">
                        <a href="/Student/Index" class="btn btn-outline-secondary rounded-3">Cancel</a>
                        <button type="submit" class="btn btn-dark rounded-3 px-4">Save</button>
                    </div>

                </form>

            </div>

        </div>
    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />

    <script>
        $("#classDropdown").change(function () {
            var selectedClass = $(this).val();

            if (selectedClass !== "") {
                $.get("/Student/GetRollNo", { studentClass: selectedClass }, function (data) {
                    $("#rollNo").val(data);
                });
            } else {
                $("#rollNo").val("");
            }
        });
    </script>
}