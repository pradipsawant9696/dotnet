@model MarksEntryViewModel

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card shadow-sm border-0 rounded-4">

                <!-- Header -->
                <div class="card-header bg-dark text-white rounded-top-4">
                    <h4 class="mb-0">Edit Student Marks</h4>
                </div>

                <div class="card-body">

                    <form method="post" asp-action="UpdateAllMarks">

                        <input type="hidden" asp-for="StudentID" />

                        <!-- Table -->
                        <div class="table-responsive">
                            <table class="table table-hover align-middle text-center mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Subject</th>
                                        <th>Marks Obtained</th>
                                        <th>Max Marks</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @for (int i = 0; i < Model.MarksList.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <input asp-for="MarksList[i].SubjectName" 
                                                       class="form-control bg-light text-center fw-semibold" readonly />
                                            </td>

                                            <td>
                                                <input asp-for="MarksList[i].MarksObtained" 
                                                       class="form-control text-center rounded-3" />
                                                <span asp-validation-for="MarksList[i].MarksObtained" class="text-danger small"></span>
                                            </td>

                                            <td>
                                                <input asp-for="MarksList[i].MaxMarks" 
                                                       class="form-control text-center rounded-3" />
                                                <span asp-validation-for="MarksList[i].MaxMarks" class="text-danger small"></span>
                                            </td>

                                            <input type="hidden" asp-for="MarksList[i].MarkID" />
                                            <input type="hidden" asp-for="MarksList[i].StudentID" />
                                        </tr>
                                    }
                                </tbody>

                            </table>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Student/Index" class="btn btn-outline-secondary rounded-3">Back</a>
                            <button class="btn btn-dark rounded-3 px-4">Update All Marks</button>
                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}