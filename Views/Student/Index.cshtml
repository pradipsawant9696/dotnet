@model System.Data.DataTable

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Student Dashboard</h2>
        <a href="/Student/Create" class="btn btn-dark rounded-3">+ Add Student</a>
    </div>

    <!-- Dashboard Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 p-3 text-center">
                <h6 class="text-muted">Total Students</h6>
                <h2 id="totalCount" class="fw-bold">@ViewBag.Total</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 p-3 text-center">
                <h6 class="text-muted">Pass</h6>
                <h2 id="passCount" class="fw-bold text-success">@ViewBag.Pass</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 p-3 text-center">
                <h6 class="text-muted">Fail</h6>
                <h2 id="failCount" class="fw-bold text-danger">@ViewBag.Fail</h2>
            </div>
        </div>
    </div>

    <!-- Filter -->
    <div class="mb-3 d-flex gap-2 align-items-center">
        <select id="classFilter" class="form-select w-auto">
            <option value="">All Classes</option>
            <option value="FY">FY</option>
            <option value="SY">SY</option>
            <option value="TY">TY</option>
        </select>
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-3 mb-3">
    <form method="post" action="/Student/SearchStudent" class="d-flex gap-2 align-items-center">

        <select name="Class" class="form-select w-auto" required>
            <option value="">Select Class</option>
            <option value="FY">FY</option>
            <option value="SY">SY</option>
            <option value="TY">TY</option>
        </select>

        <input type="number" name="RollNo" class="form-control w-auto" placeholder="Enter Roll No" required />

        <button class="btn btn-dark">Search</button>

    </form>
</div>

    <!-- Table -->
    <div class="card shadow-sm rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 text-center" id="studentTable">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Roll No</th>
                        <th>Class</th>
                        <th>Average</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (System.Data.DataRow row in Model.Rows)
                    {
                        <tr>
                            <td>@row["ID"]</td>
                            <td>@row["Name"]</td>
                            <td>@row["RollNo"]</td>
                            <td class="classCol">@row["Class"]</td>

                            <td class="avgCol">
                                @if (row["Average"].ToString() == "Not Assigned")
                                {
                                    <span class="badge bg-warning text-dark">Not Assigned</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border">
                                     
                                        @Convert.ToDouble(row["Average"]).ToString("0.00")
                                    </span>
                                }
                            </td>

                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="/Student/AddMarks/@row["ID"]" class="btn btn-sm btn-outline-warning">Marks</a>
                                    <a href="/Student/Report/@row["ID"]" class="btn btn-sm btn-outline-info">Report</a>
                                    <a href="/Student/Edit/@row["ID"]" class="btn btn-sm btn-outline-primary">Edit</a>

                                    <!-- ✅ CLEAN DELETE -->
                                    <a href="javascript:void(0);"
                                       onclick="confirmDelete('/Student/Delete/@row["ID"]')"
                                       class="btn btn-sm btn-outline-danger">
                                       Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

</div>

<!-- Script -->
<script>
    function filterTable() {
        var selectedClass = document.getElementById("classFilter").value;
        var rows = document.querySelectorAll("#studentTable tbody tr");

        let total = 0;
        let pass = 0;
        let fail = 0;

        rows.forEach(row => {
            var studentClass = row.querySelector(".classCol").innerText;
            var avgText = row.querySelector(".avgCol").innerText.trim();

            if (selectedClass === "" || studentClass === selectedClass) {
                row.style.display = "";
                total++;

                if (avgText !== "Not Assigned") {
                    let avg = parseFloat(avgText);

                    if (avg >= 40)
                        pass++;
                    else
                        fail++;
                }
            } else {
                row.style.display = "none";
            }
        });

        document.getElementById("totalCount").innerText = total;
        document.getElementById("passCount").innerText = pass;
        document.getElementById("failCount").innerText = fail;
    }

    document.getElementById("classFilter").addEventListener("change", filterTable);

    // ✅ CLEAN CONFIRM DELETE
    function confirmDelete(url) {
        if (confirm("⚠️ Are you sure you want to delete this student?")) {
            window.location.href = url;
        }
    }
</script>